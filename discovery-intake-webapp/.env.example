# Copy this file to .env (loaded automatically via dotenv), then fill in keys.
# .env.local is also still supported and takes precedence if present.
# Never commit .env or .env.local — only this .env.example template.

PORT=5177
APP_ENV=local
APP_BASE_URL=http://localhost:5177
ENTERPRISE_MODE=off
CONNECTOR_MODE=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Phase 5 — Azure AD sign-in gate (scaffolding).
# Leave AUTH_ENABLED=false until an Azure app registration is wired; the app
# runs completely un-gated while it is false. Keep all secrets blank here.
# Generate AUTH_SESSION_SECRET with: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
AUTH_ENABLED=false
AUTH_AZURE_TENANT_ID=
AUTH_AZURE_CLIENT_ID=
AUTH_AZURE_CLIENT_SECRET=
AUTH_REDIRECT_URI=http://localhost:5177/auth/microsoft/callback
AUTH_SESSION_SECRET=
AUTH_SESSION_TTL_HOURS=12
# Comma-separated Azure oids (sub) allowed to read the FULL audit log via
# GET /api/audit. Everyone else sees only their own entries. Leave blank = no admins.
AUTH_ADMIN_SUBS=

# User-facing dictation / voice settings
REALTIME_MODEL=gpt-realtime-2
REALTIME_VOICE=marin
REALTIME_REASONING_EFFORT=low
TRANSCRIPTION_MODEL=gpt-4o-transcribe

# AI "speaks back" text-to-speech (OpenAI).
# TTS_VOICE accepts any OpenAI preset voice: alloy, echo, fable, onyx, nova, shimmer, etc.
# Change it here (or in .env.local) and restart the server — no code changes needed.
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=alloy

# Structured intake extraction settings
EXTRACTION_MODEL=gpt-5.5
EXTRACTION_REASONING_EFFORT=medium
EXTRACTION_VERBOSITY=low

# Optional chat settings
CHAT_REASONING_EFFORT=low
CHAT_VERBOSITY=low

# Enterprise / Microsoft 365 connector planning
# Keep CONNECTOR_MODE=mock until Microsoft 365 permissions are approved.
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=http://localhost:5177/auth/microsoft/callback
MICROSOFT_GRAPH_SCOPES=User.Read Files.Read.All Sites.Read.All offline_access
MICROSOFT_SHAREPOINT_HOSTNAME=
MICROSOFT_SHAREPOINT_SITE_PATH=
MICROSOFT_GRAPH_SITE_ID=
MICROSOFT_GRAPH_DRIVE_ID=
MICROSOFT_GRAPH_FOLDER_PATH=

# Work GitHub repository metadata
GITHUB_REPOSITORY=
GITHUB_DEFAULT_BRANCH=main
GITHUB_ACTIONS_ENABLED=false

# Optional add-on providers
# Leave blank until procurement/security/data-handling approval is complete.
ELEVENLABS_API_KEY=
FISH_AUDIO_API_KEY=
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
LLAMAPARSE_API_KEY=
MISTRAL_API_KEY=
PRESIDIO_ENDPOINT=
AZURE_AI_LANGUAGE_ENDPOINT=
AZURE_AI_LANGUAGE_KEY=
BRAINTRUST_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
ADDON_LIVE_TEST_TIMEOUT_MS=8000
